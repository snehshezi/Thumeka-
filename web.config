<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS configuration for Plesk Windows iisnode.

  - Handler binds `server.cjs` to iisnode.
  - First rewrite serves Next.js build artifacts (/_next/static/*) directly
    from disk via IIS's static file handler — no Node round trip. This is
    the recommended pattern for Next.js behind IIS and it eliminates the
    400 / 404 errors that came from iisnode rejecting static asset requests
    during boot or under load.
  - Second rewrite routes every remaining non-file request to server.cjs so
    Next.js handles dynamic pages, route handlers, and Server Actions.
  - No `nodeProcessCommandLine` here on purpose — Plesk's per-domain Node.js
    setup writes the correct node.exe path into the inherited
    applicationHost.config. If iisnode still can't find node.exe after this,
    `npm run find-node` (see package.json) prints the path; paste it back to
    me and I'll hardcode it into this file.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.cjs" verb="*" modules="iisnode" />
    </handlers>
    <staticContent>
      <!-- Ensure modern asset MIME types are served correctly. IIS's default
           list is missing a few. -->
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>
    <rewrite>
      <rules>
        <!-- 1. Next.js build artifacts: /_next/static/* → .next/static/* on disk -->
        <rule name="Next.js static assets" stopProcessing="true">
          <match url="^_next/static/(.*)$" />
          <action type="Rewrite" url=".next/static/{R:1}" />
        </rule>
        <!-- 2. Anything else that doesn't map to a real file or folder is
             handled by Next.js. Real files (public/, favicons, etc.) are
             served by IIS's static handler. -->
        <rule name="Route everything else to Next.js" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.cjs" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
