{
  "name": "thumeka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:test": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:db:watch": "vitest --config vitest.db.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:runbook": "playwright test tests/e2e/runbook --workers=1",
    "test:e2e:runbook:headed": "playwright test tests/e2e/runbook --headed --workers=1",
    "test:all": "npm run lint && npm run test && npm run test:db && npm run test:e2e && npm run build",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "reset:dev": "tsx scripts/reset-dev.ts",
    "find-node": "node -e \"console.log('NODE PATH:', process.execPath); console.log('NODE VERSION:', process.version)\""
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "~2.0.2",
    "@sentry/nextjs": "~10.55.0",
    "@supabase/ssr": "~0.6.1",
    "@supabase/supabase-js": "~2.106.1",
    "clsx": "~2.1.1",
    "lucide-react": "~0.468.0",
    "next": "~15.5.18",
    "react": "~19.2.6",
    "react-dom": "~19.2.6",
    "resend": "~6.12.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "~4.10.2",
    "@playwright/test": "~1.53.0",
    "@testing-library/jest-dom": "~6.6.3",
    "@testing-library/react": "~16.3.2",
    "@types/node": "~22.10.0",
    "@types/react": "~19.2.15",
    "@types/react-dom": "~19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "~2.1.8",
    "autoprefixer": "~10.4.20",
    "eslint": "~9.17.0",
    "eslint-config-next": "~15.5.18",
    "jsdom": "~25.0.1",
    "postcss": "~8.4.49",
    "tailwindcss": "~3.4.17",
    "tsx": "~4.22.3",
    "typescript": "~5.7.2",
    "vitest": "~2.1.8"
  }
}
